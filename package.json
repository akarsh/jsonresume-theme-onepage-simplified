{
  "name": "jsonresume-theme-onepage-simplified",
  "version": "1.2.3",
  "description": "Simplified, compact, printable theme for JSON Resume",
  "author": "Ainsley Chong, Divyendu Singh, Akarsh Seggemu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akarsh/jsonresume-theme-onepage-simplified.git"
  },
  "bugs": {
    "url": "https://github.com/akarsh/jsonresume-theme-onepage-simplified/issues"
  },
  "homepage": "https://github.com/akarsh/jsonresume-theme-onepage-simplified",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "render": "resumed render resume.json --theme jsonresume-theme-onepage-simplified --output resume.html"
  },
  "keywords": [
    "jsonresume",
    "jsonresume-theme"
  ],
  "files": [
    "dist/",
    "index.js",
    "resume.hbs",
    "style.css"
  ],
  "dependencies": {
    "css": "^3.0.0",
    "handlebars": "^4.0.11"
  },
  "devDependencies": {
    "resumed": "^6.1.0",
    "vite": "^8.0.3",
    "vite-plugin-handlebars": "^2.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}